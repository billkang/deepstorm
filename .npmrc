registry=https://registry.npmmirror.com/

# npm publish 认证（token 从 .env 加载）
#   设置：npm config set //registry.npmjs.org/:_authToken \$NPM_TOKEN --location project
#   结果：//registry.npmjs.org/:_authToken=\${NPM_TOKEN}
#   发布前：确保 .env 中有 NPM_TOKEN，然后 source .env
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
